VITE_SITE_URL=https://edio-iq.com
JWT_SECRET=
EDIO_AUTH_COOKIE_NAME=edio_session
EDIO_AUTH_COOKIE_SECURE=true

# Supabase Auth for static Hostinger deployment
VITE_SUPABASE_URL=
