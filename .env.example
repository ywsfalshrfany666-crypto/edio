ALWASEET_USERNAME=
ALWASEET_PASSWORD=
ALWASEET_API_TOKEN=
ALWASEET_DRY_RUN=true
ALWASEET_DEFAULT_PACKAGE_SIZE_ID=
ALWASEET_DEFAULT_ORDER_TYPE=audio_gear

# Google OAuth / OpenID Connect
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
